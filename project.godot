; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="TAKO"
run/main_scene="res://scenes/core/game_manager.tscn"
config/features=PackedStringArray("4.6", "GL Compatibility")
config/icon="res://icon.svg"

[autoload]

GameLogger="*res://scripts/core/logger.gd"
Modules="*res://scripts/core/modules.gd"
Globals="*res://scripts/core/globals.gd"
SceneManager="*res://scripts/core/scene_manager.gd"
DialogueManager="*res://scripts/core/dialogue_manager.gd"
GameManager="*res://scripts/core/game_manager.gd"
PlayerDataManager="*res://scripts/core/player_data_manager.gd"
AudioManager="*res://scripts/core/audio_manager.gd"
ApiClient="*res://scripts/core/api_client.gd"
DatabaseManager="*res://scripts/SQLite/db_manager.gd"
AuthManager="*res://scripts/core/auth_manager.gd"
SupabaseSyncManager="*res://scripts/core/supabase_sync_manager.gd"
MathManager="*res://scripts/gameplay/math/math_manager.gd"
_mcp_game_helper="*res://addons/godot_ai/runtime/game_helper.gd"

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/subwindows/embed_subwindows=false
window/stretch/mode="viewport"

[editor_plugins]

+enabled=PackedStringArray("res://addons/godot-sqlite/plugin.cfg", "res://addons/godot_ai/plugin.cfg")

